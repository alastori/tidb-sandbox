# Lab 12 — PG → TiDB Debezium CDC
# Copy to .env and customize as needed

# Timestamp (leave empty for auto-generation in UTC)
TS=

# Results directory (defaults to ./results)
RESULTS_DIR=

# Docker images — pinned to exact versions
PG_IMAGE=postgres:16.6
PD_IMAGE=pingcap/pd:v8.5.4
TIKV_IMAGE=pingcap/tikv:v8.5.4
TIDB_IMAGE=pingcap/tidb:v8.5.4
KAFKA_IMAGE=confluentinc/cp-kafka:7.6.0
ZK_IMAGE=confluentinc/cp-zookeeper:7.6.0
MYSQL_CLIENT_IMAGE=mysql:8.0.44
DEBEZIUM_IMAGE=quay.io/debezium/connect:2.5.4.Final

# PostgreSQL
PG_DB=smoketest
PG_USER=postgres
PG_PASSWORD=postgres

# Ports
PG_PORT=5432
TIDB_PORT=4000
CONNECT_PORT=8083

# CDC replication wait (seconds)
CDC_WAIT=15
