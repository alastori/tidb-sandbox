# Lab 11 — Cloud Proxy Failover (HAProxy / ProxySQL)
# Copy to .env and fill in real values

# Unified credentials (same user on both clusters)
PROXY_USER=                          # e.g., 3HeeAGkLDr83GqD.root
PROXY_PASSWORD=

# TiDB Cloud — Dedicated
DEDICATED_HOST=                      # e.g., tidb.xxx.clusters.dev.tidb-cloud.com
DEDICATED_PORT=4000

# TiDB Cloud — Essential
ESSENTIAL_HOST=                      # e.g., gateway01.us-east-1.prod.aws.tidbcloud.com
ESSENTIAL_PORT=4000

# Probe settings
PROBE_DURATION=60
PROBE_INTERVAL=2
