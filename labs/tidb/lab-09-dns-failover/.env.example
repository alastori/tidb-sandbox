# Lab 09 — DNS Failover
# Copy to .env and customize as needed

# Database credentials (TiDB unistore defaults: root with empty password)
# TIDB_USER=root
# TIDB_PASSWORD=

# Probe settings
# PROBE_DURATION=30
# PROBE_INTERVAL=0.5

# DNS flip timing
# PRE_FLIP=10
# POST_FLIP=20

# Health check
# MAX_RETRIES=30
# RETRY_INTERVAL=2

# Results directory (default: ./results)
# RESULTS_DIR=
