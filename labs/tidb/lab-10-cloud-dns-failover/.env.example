# Lab 10 — Cloud DNS Failover (Dedicated ↔ Essential)
# Copy to .env and fill in real values

# TiDB Cloud — Dedicated
DEDICATED_HOST=                      # e.g., gateway01.us-east-1.prod.aws.tidbcloud.com
DEDICATED_PORT=4000
DEDICATED_USER=root
DEDICATED_PASSWORD=

# TiDB Cloud — Essential
ESSENTIAL_HOST=                      # e.g., gateway01.us-east-1.shared.aws.tidbcloud.com
ESSENTIAL_PORT=4000
ESSENTIAL_USER=                      # e.g., 3r7ao4hqor9FNjp.root
ESSENTIAL_PASSWORD=

# Probe settings
PROBE_DURATION=60
PROBE_INTERVAL=2
