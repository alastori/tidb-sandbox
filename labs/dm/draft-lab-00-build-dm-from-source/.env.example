# Build configuration
# TIFLOW_REPO=https://github.com/pingcap/tiflow.git
# TIFLOW_DIR=./tiflow                # Local clone directory
# DM_IMAGE_TAG=dm:local              # Docker image tag for the built image
# GO_VERSION=1.23                    # Minimum Go version

# Branch build (build-from-branch.sh)
# TIFLOW_BRANCH=release-8.5          # Branch to build from

# PR build (build-from-pr.sh)
# PR_NUMBER=12351                    # PR number to build

# Multi-PR build (build-from-multi-pr.sh)
# PR_NUMBERS="12351 12414 12329"     # Space-separated PR numbers
# BASE_BRANCH=release-8.5            # Base branch to cherry-pick onto
