# Lab 05 — DM Shard Merge Migration
# Copy to .env and customize if needed

# Versions
MYSQL_IMAGE=mysql:8.0.44
TIDB_VERSION=v8.5.4
DM_VERSION=v8.5.4

# MySQL root password (shared across all shards)
MYSQL_ROOT_PASSWORD=Pass_1234

# Seed data: rows per shard (100K default)
ROWS_PER_SHARD=100000

# Health check tuning
MAX_RETRIES=30
RETRY_INTERVAL=2
